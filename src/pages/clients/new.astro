---
import Layout from '../../layouts/DocumentLayout.astro';
import { getDb } from '../../db';

const db = getDb(Astro);
import { clients, contacts } from '../../db/schema';

const PHONE_CODES = [
  { code: '+57',  label: '+57 · Colombia' },
  { code: '+1',   label: '+1 · EE.UU.' },
  { code: '+52',  label: '+52 · México' },
  { code: '+54',  label: '+54 · Argentina' },
  { code: '+56',  label: '+56 · Chile' },
  { code: '+51',  label: '+51 · Perú' },
  { code: '+58',  label: '+58 · Venezuela' },
  { code: '+593', label: '+593 · Ecuador' },
  { code: '+591', label: '+591 · Bolivia' },
  { code: '+595', label: '+595 · Paraguay' },
  { code: '+598', label: '+598 · Uruguay' },
  { code: '+34',  label: '+34 · España' },
  { code: '+44',  label: '+44 · Reino Unido' },
];

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const company = formData.get('company')?.toString().trim();
  const notes = formData.get('notes')?.toString().trim();
  const name = formData.get('name')?.toString().trim();
  const email = formData.get('email')?.toString().trim();
  const phoneCode = formData.get('phoneCode')?.toString() || '+57';
  const phoneNumber = formData.get('phoneNumber')?.toString().trim() || '';
  const phone = phoneNumber ? `${phoneCode} ${phoneNumber}` : '';

  if (!company || !name || !email) {
    error = 'Los campos nombre de empresa, nombre del contacto y correo son requeridos.';
  } else {
    try {
      const [newContact] = await db.insert(contacts).values({
        name,
        email,
        phone: phone || null,
      }).returning();

      await db.insert(clients).values({
        companyName: company,
        notes: notes || null,
        contactId: newContact.id,
      }).returning();

      return Astro.redirect('/clients');
    } catch (e: any) {
      error = e.message || 'Error al crear el cliente.';
    }
  }
}
---

<Layout title="Nuevo Cliente — Renovio">
  <div class="col-narrow">
    <div class="breadcrumb">
      <a href="/clients" class="breadcrumb-link">Clientes</a>
      <span class="breadcrumb-sep">›</span>
      <span>Nuevo</span>
    </div>
    <div class="page-eyebrow">Registro</div>
    <h1 class="page-title">Nuevo cliente</h1>
    <p class="page-subtitle">Ingrese los datos de la empresa y su contacto principal.</p>

    {error && <div class="login-error" style="margin-bottom: 1rem;">{error}</div>}

    <form method="POST">
      <div class="form-section-title">Empresa</div>

      <div class="form-field">
        <label class="form-label" for="company">Nombre de la empresa *</label>
        <input class="form-input" type="text" id="company" name="company" placeholder="Ej. Geoark Studio" required />
      </div>

      <div class="form-field">
        <label class="form-label" for="notes">Notas internas</label>
        <input class="form-input" type="text" id="notes" name="notes" placeholder="Contexto del cliente…" />
      </div>

      <div class="form-section-title">Contacto principal</div>

      <div class="form-field">
        <label class="form-label" for="name">Nombre completo *</label>
        <input class="form-input" type="text" id="name" name="name" placeholder="Nombre del contacto" required />
      </div>

      <div class="form-field">
        <label class="form-label" for="email">Correo *</label>
        <input class="form-input" type="email" id="email" name="email" placeholder="correo@empresa.com" required />
      </div>

      <div class="form-field">
        <label class="form-label" for="phoneNumber">Teléfono</label>
        <div style="display: flex; gap: 0.375rem;">
          <select class="form-select" name="phoneCode" id="phoneCode" style="width: 160px; flex-shrink: 0;">
            {PHONE_CODES.map(p => <option value={p.code}>{p.label}</option>)}
          </select>
          <input class="form-input" type="tel" id="phoneNumber" name="phoneNumber"
            placeholder="300 000 0000" style="flex: 1; min-width: 0;" />
        </div>
      </div>

      <div style="display: flex; gap: 0.75rem; margin-top: 1rem;">
        <button type="submit" class="btn btn-primary">Registrar cliente</button>
        <a href="/clients" class="btn btn-ghost">Cancelar</a>
      </div>
    </form>
  </div>
</Layout>