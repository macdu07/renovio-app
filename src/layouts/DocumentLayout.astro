---
import '../styles/global.css';
import ClientRouter from 'astro/components/ClientRouter.astro';

interface Props {
  title?: string;
  description?: string;
  showNav?: boolean;
}

const {
  title = 'Renovio',
  description = 'Control de renovaciones web',
  showNav = true,
} = Astro.props;

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Panel' },
  { href: '/clients', label: 'Clientes' },
  { href: '/logs', label: 'Notificaciones' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&display=optional" rel="stylesheet" />
  <ClientRouter />
  <title>{title}</title>
  <script is:inline>
    // Apply saved theme before first paint to avoid FOUC
    (function () {
      try {
        const saved = localStorage.getItem('renovio-theme');
        if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      } catch (_) {}
    })();
  </script>
</head>
<body>
  <div class="page-wrap">
    {showNav && <nav class="nav" transition:persist>
      <div class="nav-inner">
        <a href="/" class="nav-logo">Renovio</a>
        <div class="nav-links">
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={['nav-link', { active: isActive(link.href) }]}
            >
              {link.label}
            </a>
          ))}
        </div>
        <div class="nav-right">
          <a href="/account" class="nav-user nav-user--link">Mi cuenta</a>
          <button
            id="theme-toggle-btn"
            class="theme-toggle"
            aria-label="Cambiar tema"
            title="Cambiar tema"
          >
            <!-- Sun icon (shown in dark mode) -->
            <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <!-- Moon icon (shown in light mode) -->
            <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
          <form action="/logout" method="POST" style="display: inline;">
            <button type="submit" class="nav-logout">Salir</button>
          </form>
        </div>
      </div>
    </nav>}
    <main class="main" transition:animate="fade">
      <slot />
    </main>
  </div>
</body>
<script>
  function applyTheme(root: HTMLElement) {
    try {
      const saved = localStorage.getItem('renovio-theme');
      if (saved === 'dark') {
        root.setAttribute('data-theme', 'dark');
      } else {
        root.removeAttribute('data-theme');
      }
    } catch (_) {}
  }

  function updateActiveLink() {
    const path = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach(link => {
      const href = link.getAttribute('href') ?? '';
      const isActive = href === '/' ? path === '/' : path.startsWith(href);
      link.classList.toggle('active', isActive);
    });
  }

  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle-btn');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      if (isDark) {
        document.documentElement.removeAttribute('data-theme');
        try { localStorage.setItem('renovio-theme', 'light'); } catch (_) {}
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
        try { localStorage.setItem('renovio-theme', 'dark'); } catch (_) {}
      }
    });
  }

  // Apply theme BEFORE the DOM swap so there's no flash or reset between pages
  document.addEventListener('astro:before-swap', (e) => {
    applyTheme((e as any).newDocument.documentElement);
  });

  // Runs on first load and after every ClientRouter navigation
  document.addEventListener('astro:page-load', () => {
    updateActiveLink();
    initThemeToggle();
  });
</script>
</html>