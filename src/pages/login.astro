---
import Layout from '../layouts/DocumentLayout.astro';

const error = Astro.url.searchParams.get('error');
---

<Layout title="Login — Renovio">
  <div class="login-wrap">
    <div class="login-box fade-in">
      <div class="login-logo">Renovio</div>
      <div class="login-title">Acceso administrativo</div>
      <div class="login-sub">Control de renovaciones web.</div>

      {error && <div class="login-error">{error}</div>}

      <form id="loginForm">
        <div class="form-field">
          <label class="form-label" for="email">Correo electrónico</label>
          <input class="form-input" type="email" id="email" name="email"
            placeholder="admin@renovio.app" required />
        </div>
        <div class="form-field">
          <label class="form-label" for="password">Contraseña</label>
          <input class="form-input" type="password" id="password" name="password"
            placeholder="••••••••" required />
        </div>
        <button class="btn btn-primary" type="submit" style="width: 100%; justify-content: center; margin-top: 0.5rem;">
          Ingresar
        </button>
      </form>
      <div id="loginError" class="login-error" style="display: none; margin-top: 1rem;"></div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('loginForm');
  const errorDiv = document.getElementById('loginError');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formEl = form as HTMLFormElement;
    const email = (formEl.querySelector('#email') as HTMLInputElement)?.value;
    const password = (formEl.querySelector('#password') as HTMLInputElement)?.value;

    try {
      const response = await fetch('/api/login', {
        method: 'POST',
        body: new URLSearchParams({ email: email || '', password: password || '' }),
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        credentials: 'same-origin',
      });

      if (response.redirected) {
        window.location.href = response.url;
      } else {
        const url = new URL(response.url);
        const err = url.searchParams.get('error');
        if (errorDiv && err) {
          errorDiv.textContent = err.replace(/\+/g, ' ');
          errorDiv.style.display = 'block';
        }
      }
    } catch (err) {
      if (errorDiv) {
        errorDiv.textContent = 'Error de conexión';
        errorDiv.style.display = 'block';
      }
    }
  });
</script>

<style>
  .login-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 52px);
  }
</style>