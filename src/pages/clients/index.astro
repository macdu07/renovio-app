---
import Layout from '../../layouts/DocumentLayout.astro';
import { getDb } from '../../db';
import { clients, services, contacts } from '../../db/schema';
import { eq } from 'drizzle-orm';

let allClients: any[] = [];
let allServices: any[] = [];
let pageError = '';

try {
  const db = getDb(Astro);

  allClients = await db.select({
    id: clients.id,
    companyName: clients.companyName,
    domain: clients.domain,
    notes: clients.notes,
    contactName: contacts.name,
    contactEmail: contacts.email,
  }).from(clients).leftJoin(contacts, eq(clients.contactId, contacts.id));

  allServices = await db.select({
    id: services.id,
    clientId: services.clientId,
    expiryDate: services.expiryDate,
  }).from(services);
} catch (err: any) {
  pageError = String(err.message || err);
}

const NOW = new Date();
function daysUntil(dateStr: string | Date | null): number {
  if (!dateStr) return 999;
  return Math.round((new Date(dateStr).getTime() - NOW.getTime()) / 86400000);
}

const clientServiceSummary = allClients.map(c => {
  const svcs = allServices.filter(s => s.clientId === c.id);
  const badCount = svcs.filter(s => daysUntil(s.expiryDate) <= 15).length;
  return { ...c, totalServices: svcs.length, badCount };
});
---

<Layout title="Clientes — Renovio">
  <div class="col">
    <div class="page-eyebrow">Directorio</div>
    <div class="detail-head" style="margin-bottom: 0.3rem;">
      <h1 class="page-title">Clientes</h1>
      <div class="detail-head-actions">
        <a href="/clients/new" class="btn btn-primary">+ Nuevo cliente</a>
      </div>
    </div>
    <p class="page-subtitle">{allClients.length} clientes registrados en la base de datos.</p>

    {pageError && (
      <div style="background: #fee2e2; border: 1px solid #ef4444; color: #b91c1c; padding: 1rem; border-radius: 6px; margin: 1rem 0;">
        <strong>Error:</strong> {pageError}
      </div>
    )}

    <div class="search-wrap">
      <input class="search-input" id="searchInput" placeholder="Buscar por empresa o dominio…" type="text" />
    </div>

    <table class="data-table" id="clientsTable">
      <thead>
        <tr>
          <th>Empresa</th>
          <th>Dominio</th>
          <th class="col-right">Servicios</th>
          <th>Alertas</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {clientServiceSummary.map(c => (
          <tr>
            <td style="padding: 10px 8px">
              <a href={`/clients/${c.id}`} class="btn-link">{c.companyName}</a>
            </td>
            <td style="padding: 10px 8px" class="col-mono">{c.domain || '—'}</td>
            <td style="padding: 10px 8px" class="col-right">{c.totalServices}</td>
            <td style="padding: 10px 8px">
              {c.badCount > 0
                ? <span class="status-badge status-warn">{c.badCount} próximo{c.badCount > 1 ? 's' : ''}</span>
                : <span class="status-badge status-ok">Sin alertas</span>
              }
            </td>
            <td style="padding: 10px 8px; text-align: right;">
              <a href={`/clients/${c.id}`} class="btn btn-ghost btn-sm">Ver →</a>
            </td>
          </tr>
        ))}
        {allClients.length === 0 && (
          <tr><td colspan="5" class="empty-state" style="padding: 3rem">No hay clientes registrados.</td></tr>
        )}
      </tbody>
    </table>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const table = document.getElementById('clientsTable') as HTMLTableElement;
  const rows = table.querySelectorAll('tbody tr');

  searchInput.addEventListener('input', (e) => {
    const term = (e.target as HTMLInputElement).value.toLowerCase();
    rows.forEach(row => {
      const text = row.textContent?.toLowerCase() || '';
      (row as HTMLElement).style.display = text.includes(term) ? '' : 'none';
    });
  });
</script>