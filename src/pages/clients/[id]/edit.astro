---
import Layout from '../../../layouts/DocumentLayout.astro';
import { getDb } from '../../../db';

const db = await getDb();
import { clients, contacts } from '../../../db/schema';
import { eq } from 'drizzle-orm';

const PHONE_CODES = [
  { code: '+57',  label: '+57 · Colombia' },
  { code: '+1',   label: '+1 · EE.UU.' },
  { code: '+52',  label: '+52 · México' },
  { code: '+54',  label: '+54 · Argentina' },
  { code: '+56',  label: '+56 · Chile' },
  { code: '+51',  label: '+51 · Perú' },
  { code: '+58',  label: '+58 · Venezuela' },
  { code: '+593', label: '+593 · Ecuador' },
  { code: '+591', label: '+591 · Bolivia' },
  { code: '+595', label: '+595 · Paraguay' },
  { code: '+598', label: '+598 · Uruguay' },
  { code: '+34',  label: '+34 · España' },
  { code: '+44',  label: '+44 · Reino Unido' },
];

// Longest codes first to avoid prefix collisions
const PARSE_ORDER = ['+593', '+595', '+591', '+598', '+57', '+52', '+54', '+56', '+51', '+58', '+34', '+44', '+1'];

const { id } = Astro.params;

const [client] = await db.select().from(clients).where(eq(clients.id, id!));
if (!client) return Astro.redirect('/clients');

const contact = client.contactId
  ? (await db.select().from(contacts).where(eq(contacts.id, client.contactId)))[0] ?? null
  : null;

const rawPhone = contact?.phone ?? '';
let initPhoneCode = '+57';
let initPhoneNumber = rawPhone;
if (rawPhone.startsWith('+')) {
  const match = PARSE_ORDER.find(c => rawPhone.startsWith(c));
  if (match) { initPhoneCode = match; initPhoneNumber = rawPhone.slice(match.length).trim(); }
}

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const company = formData.get('company')?.toString().trim();
  const notes = formData.get('notes')?.toString().trim() || null;
  const name = formData.get('name')?.toString().trim();
  const email = formData.get('email')?.toString().trim();
  const phoneCode = formData.get('phoneCode')?.toString() || '+57';
  const phoneNumber = formData.get('phoneNumber')?.toString().trim() || '';
  const phone = phoneNumber ? `${phoneCode} ${phoneNumber}` : null;

  if (!company || !name || !email) {
    error = 'El nombre de empresa, nombre del contacto y correo son requeridos.';
  } else {
    try {
      await db.update(clients).set({ companyName: company, notes }).where(eq(clients.id, id!));

      if (contact) {
        await db.update(contacts).set({ name, email, phone }).where(eq(contacts.id, contact.id));
      }

      return Astro.redirect(`/clients/${id}`);
    } catch (e: any) {
      error = e.message || 'Error al actualizar el cliente.';
    }
  }
}
---

<Layout title="Editar Cliente — Renovio">
  <div class="col-narrow">
    <div class="breadcrumb">
      <a href="/clients" class="breadcrumb-link">Clientes</a>
      <span class="breadcrumb-sep">›</span>
      <a href={`/clients/${id}`} class="breadcrumb-link">{client.companyName}</a>
      <span class="breadcrumb-sep">›</span>
      <span>Editar</span>
    </div>
    <div class="page-eyebrow">Edición</div>
    <h1 class="page-title">Editar cliente</h1>
    <p class="page-subtitle">Modifique los datos de la empresa y su contacto principal.</p>

    {error && <div class="login-error" style="margin-bottom: 1rem;">{error}</div>}

    <form method="POST">
      <div class="form-section-title">Empresa</div>

      <div class="form-field">
        <label class="form-label" for="company">Nombre de la empresa *</label>
        <input class="form-input" type="text" id="company" name="company"
          value={client.companyName} required />
      </div>

      <div class="form-field">
        <label class="form-label" for="notes">Notas internas</label>
        <input class="form-input" type="text" id="notes" name="notes"
          placeholder="Contexto del cliente…" value={client.notes ?? ''} />
      </div>

      <div class="form-section-title">Contacto principal</div>

      <div class="form-field">
        <label class="form-label" for="name">Nombre completo *</label>
        <input class="form-input" type="text" id="name" name="name"
          value={contact?.name ?? ''} required />
      </div>

      <div class="form-field">
        <label class="form-label" for="email">Correo *</label>
        <input class="form-input" type="email" id="email" name="email"
          value={contact?.email ?? ''} required />
      </div>

      <div class="form-field">
        <label class="form-label" for="phoneNumber">Teléfono</label>
        <div style="display: flex; gap: 0.375rem;">
          <select class="form-select" name="phoneCode" id="phoneCode" style="width: 160px; flex-shrink: 0;">
            {PHONE_CODES.map(p => (
              <option value={p.code} selected={p.code === initPhoneCode}>{p.label}</option>
            ))}
          </select>
          <input class="form-input" type="tel" id="phoneNumber" name="phoneNumber"
            placeholder="300 000 0000" value={initPhoneNumber}
            style="flex: 1; min-width: 0;" />
        </div>
      </div>

      <div style="display: flex; gap: 0.75rem; margin-top: 1rem;">
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
        <a href={`/clients/${id}`} class="btn btn-ghost">Cancelar</a>
      </div>
    </form>
  </div>
</Layout>
