---
import Layout from '../layouts/DocumentLayout.astro';
import { neon } from '@neondatabase/serverless';

const session = Astro.cookies.get('session')?.value;
if (!session) return Astro.redirect('/login');

const userId = session.replace('user-', '');

let user = { email: '' };

if (import.meta.env.DATABASE_URL) {
  const sql = neon(import.meta.env.DATABASE_URL);
  const result = await sql`SELECT email FROM users WHERE id = ${userId} LIMIT 1`;
  if (result.length > 0) {
    user = result[0] as typeof user;
  }
}

const url = new URL(Astro.url);
const successMsg = url.searchParams.get('success');
const errorMsg = url.searchParams.get('error');
---

<Layout title="Renovio — Configuración de cuenta">
  <div class="col" style="max-width: 560px;">
    <div class="page-eyebrow">Cuenta</div>
    <h1 class="page-title">Configuración</h1>
    <p class="page-subtitle">Actualiza tu correo y contraseña de acceso.</p>

    {successMsg && (
      <div class="account-alert account-alert--ok" role="alert">
        {decodeURIComponent(successMsg)}
      </div>
    )}
    {errorMsg && (
      <div class="account-alert account-alert--err" role="alert">
        {decodeURIComponent(errorMsg)}
      </div>
    )}

    <!-- Profile section -->
    <section class="account-section">
      <div class="form-section-title">Correo electrónico</div>
      <form method="POST" action="/api/account" id="form-profile">
        <input type="hidden" name="action" value="profile" />
        <div class="form-field">
          <label class="form-label" for="email">Correo</label>
          <input
            id="email"
            name="email"
            type="email"
            class="form-input"
            value={user.email}
            required
            autocomplete="email"
          />
        </div>
        <div class="account-actions">
          <button type="submit" class="btn btn-primary btn-sm">Guardar correo</button>
        </div>
      </form>
    </section>

    <hr class="rule" />

    <!-- Password section -->
    <section class="account-section">
      <div class="form-section-title">Contraseña</div>
      <form method="POST" action="/api/account" id="form-password">
        <input type="hidden" name="action" value="password" />
        <div class="form-field">
          <label class="form-label" for="current_password">Contraseña actual</label>
          <input
            id="current_password"
            name="current_password"
            type="password"
            class="form-input"
            required
            autocomplete="current-password"
          />
        </div>
        <div class="form-field">
          <label class="form-label" for="new_password">Nueva contraseña</label>
          <input
            id="new_password"
            name="new_password"
            type="password"
            class="form-input"
            required
            autocomplete="new-password"
            minlength="8"
          />
          <div class="form-hint">Mínimo 8 caracteres.</div>
        </div>
        <div class="form-field">
          <label class="form-label" for="confirm_password">Confirmar nueva contraseña</label>
          <input
            id="confirm_password"
            name="confirm_password"
            type="password"
            class="form-input"
            required
            autocomplete="new-password"
          />
        </div>
        <div class="account-actions">
          <button type="submit" class="btn btn-primary btn-sm">Cambiar contraseña</button>
        </div>
      </form>
    </section>

    <hr class="rule" />

    <div class="account-danger-zone">
      <form action="/logout" method="POST">
        <button type="submit" class="btn btn-ghost btn-sm">Cerrar sesión</button>
      </form>
    </div>
  </div>
</Layout>

<style>
  .account-section {
    margin-bottom: 0.5rem;
  }

  .account-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }

  .account-alert {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    padding: 10px 14px;
    border-radius: 3px;
    margin-bottom: 1.5rem;
    border: 1px solid;
  }

  .account-alert--ok {
    background: rgba(42,122,75,0.07);
    color: var(--accent-green);
    border-color: rgba(42,122,75,0.2);
  }

  .account-alert--err {
    background: rgba(176,48,48,0.06);
    color: var(--accent-red);
    border-color: rgba(176,48,48,0.18);
  }

  .account-danger-zone {
    padding-bottom: 2rem;
  }
</style>
